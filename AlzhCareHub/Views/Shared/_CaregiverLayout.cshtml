<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Caregiver Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
        <style>
            body{
                overflow-x: hidden;
            }
        span{
            border-radius: 50%;
            padding: 2px 10px;
            border: 2px solid #458ff6;
            color: #fff;
            background-color: #458ff6;
        }
        /*footer Designing*/
        .footer {
            background: linear-gradient(to right, #65c7f7, #0052d4);
            padding: 40px 0;
        }

        .footer-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background-color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 20px;
        }
        ul li a{
            text-decoration: none;
            color: #c3dffa;
        }

        .footer-section{
            margin-left: 10rem;
        }
     </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg" style="color: #ffffff">
        <div class="container-fluid">
      
            <a class="navbar-brand ms-5" href="#"><span class="me-2">A</span>AlzhCare</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <!-- Pushes items to the right -->
                    <li class="nav-item">
                        <a class="nav-link active" href="#">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Find a Doctor</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Educational Resources</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">About Us</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Donate</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link me-5" asp-area="" asp-controller="Auth" asp-action="Logout">Logout</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-4">
        @RenderBody()  @* This is required *@
    </div>
    <footer class="footer text-center text-lg-start" style="width: 100vw; height: 45vh; color: white;">
        <div class="container text-center text-md-start">
            <div class="row">
                <div class="col-md-4 col-lg-3">
                    <div class="footer-icon" style="color: #70a7f5">A</div>
                    <h5>AlzhCare</h5>
                    <p style="color: #c3dffa;">AlzhCare Hub A platform where there is a release of burden from Caregivers to their Old People for take care.</p>
                </div>

                <div class="col-md-2 col-lg-2 footer-section">
                    <h5>Home</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">About</a></li>
                        <li><a href="#">Testimonials</a></li>
                        <li><a href="#">Find a doctor</a></li>
                        <li><a href="#">Apps</a></li>
                    </ul>
                </div>

                <div class="col-md-2 col-lg-2">
                    <h5>Region</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Lahore</a></li>
                        <li><a href="#">Karachi</a></li>
                        <li><a href="#">Islamabad</a></li>
                        <li><a href="#">Mulla Wala</a></li>
                    </ul>
                </div>

                <div class="col-md-2 col-lg-2">
                    <h5>Help</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Help center</a></li>
                        <li><a href="#">Contact support</a></li>
                        <li><a href="#">Instructions</a></li>
                        <li><a href="#">How it works</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="px-5 text-center" style="margin-left: 4rem;">
            &copy; AlzhCare Hub. All rights reserved
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
</body>
</html>

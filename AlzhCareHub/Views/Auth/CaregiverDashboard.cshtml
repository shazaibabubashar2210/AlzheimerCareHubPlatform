@{
    Layout = "_CaregiverLayout";
}
<!-- Caregiver-specific content -->
<head>
    <link href="~/css/caregiverpagedesigning.css" rel="stylesheet" />
</head>

<!-- Hero Section -->
<div class="container my-5">
    <div class="row align-items-center hero">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <h1 class="display-5 fw-bold">Virtual healthcare for you</h1>
            <p class="text-muted">
                Alzheimer's and dementia don't come with an instruction manual, but there are resources available to help you.
            </p>
            <a href="#" class="btn btn-primary btn-lg helpbtn">Get Help</a>
        </div>
        <div class="col-lg-6">
            <img src="~/images/HeroSectionImage.png" alt="Virtual Healthcare" class="img-fluid">
        </div>
    </div>
</div>

<!-- Our Services Section -->
<div class="container my-5">
    <div class="text-center mb-4">
        <h2 class="fw-bold">Our Services</h2>
        <div class="rowborder"></div>
        <p class="text-muted mb-5">
            At AlzhCare, we are committed to providing comprehensive support to caregivers of Alzheimer’s patients. Our<br /> platform offers a variety of services to make caregiving easier, more effective, and engaging. Here’s what we offer:
        </p>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body">
                    <img src="~/images/reminder.png" class="iconimg" />
                    <h5 class="card-title mt-3">Reminder & Alerts</h5>
                    <p class="card-text">Choose your doctor from thousands of specialist, general, and trusted hospitals.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body">
                    <img src="~/images/trainingresouces.png" class="iconimg" />
                    <h5 class="card-title mt-3">Training Resources</h5>
                    <p class="card-text">Buy your medicines with our mobile application with a simple delivery system.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body">
                    <img src="~/images/games.png" class="iconimg" />
                    <h5 class="card-title mt-3">Games</h5>
                    <p class="card-text">Free consultation with our trusted doctors and get the best recommendations.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body">
                    <img src="~/images/appointment.png" class="iconimg" />
                    <h5 class="card-title mt-3">Doctor Appointments</h5>
                    <p class="card-text">Free consultation with our trusted doctors and get the best recommendations.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body">
                    <img src="~/images/feedback.png" class="iconimg" />
                    <h5 class="card-title mt-3">Feedback</h5>
                    <p class="card-text">You can get 24/7 urgent care for yourself or your family.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card shadow border-0">
                <div class="card-body">
                    <img src="~/images/faq.webp" class="iconimg" />
                    <h5 class="card-title mt-3">FAQ</h5>
                    <p class="card-text">Track and read about Alzheimer’s disease: what it is and how it started.</p>
                </div>
            </div>
        </div>
    </div>
    <div class="text-center mt-4">
        <a href="#" class="btn btn-outline-primary btn-lg helpbtn">Learn more</a>
    </div>
</div>
<!-- Join Us Section -->
<div class="container support-section">
    <div>
        <img src="~/images/JoinUs.png" alt="Supporting Alzheimer's Patients">
    </div>
    <div class="support-content">
        <h2>Join Us in Supporting Alzheimer's Patients</h2>
        <p>
            Join our volunteer team and enrich the lives of Alzheimer's patients. Your support can make a profound difference.
        </p>
        <a href="#" class="btn btn-outline-primary helpbtn">Learn more</a>
    </div>
    
</div>

<!-- Donate Section -->
<div class="container support-section">
    <div class="support-content">
        <h2>Donate to Alzheimer's Support</h2>
        <p>
            Your generosity fuels vital research and support for Alzheimer's patients. Give today and be a part of the solution.
        </p>
        <a href="#" class="btn btn-outline-primary helpbtn">Donate</a>
    </div>
    <div>
        <img src="~/images/Donate.png" alt="Supporting Alzheimer's Patients" >
    </div>
</div>
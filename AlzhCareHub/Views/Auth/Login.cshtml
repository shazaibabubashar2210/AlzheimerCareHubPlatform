@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Page - AlzhCareHub</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .container {
            max-width: 900px;
            background-color: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            display: flex;
            align-items: center;
        }

        .image-container img {
            height: 450px;
            width: 350px;
            border-radius: 10px;
            object-fit: cover;
        }

        .form-container {
            padding: 10px;
            margin-left: 20px;
        }

        .form-control {
            margin-bottom: 15px;
            border-radius: 20px;
            padding: 10px;
        }

        .btn-primary {
            width: 100%;
            border-radius: 20px;
            padding: 10px;
            margin-top: 10px;
        }

        .btn-outline-primary {
            width: 100%;
            border-radius: 20px;
            padding: 10px;
        }

        .form-control::placeholder {
            color: #6c757d;
            opacity: 0.8;
        }

        .text-center {
            text-align: center;
        }

        h2 {
            margin-bottom: 1.5rem;
            font-weight: 600;
        }

        .alert {
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="image-container col-6">
            <img src="~/images/signupimage.png" alt="Login Image" />
        </div>

        <div class="form-container col-6 mt-5">
            <h2 class="text-center mb-4">Welcome to AlzhCareHub</h2>
            <p class="text-center mb-4">Providing care and support for Alzheimer’s patients and caregivers</p>

            @* Display TempData message if available *@
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success text-center">
                    @TempData["Message"]
                </div>
            }

            @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
            {
                <div class="mb-3">
                    <input type="email" name="email"
                           class="form-control"
                           placeholder="Enter your email"
                           required>
                </div>
                <div class="mb-3">
                    <input type="password" name="password"
                           class="form-control"
                           placeholder="Enter your password"
                           required>
                </div>
                <button type="submit" class="btn btn-primary">Login</button>
            }

            <p class="mt-3">
                Don't have an account?
                <a asp-controller="Auth" asp-action="Register">Create account</a>
                <a asp-controller="Auth" asp-action="ForgotPassword">Reset Password</a>
            </p>
         
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-auth.js"></script>

</body>
</html>

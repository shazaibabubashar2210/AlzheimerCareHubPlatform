@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Page - AlzhCareHub</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/loginpagedesigning.css" rel="stylesheet" />
</head>
<body>
    <div class="container">
        <div class="image-container col-6">
            <img src="~/images/signupimage.jpg" alt="Login Image" />
        </div>

        <div class="form-container col-6 mt-5">
            <h2 class="text-center mb-4">Welcome to AlzhCareHub</h2>
            <p class="text-center mb-4">Providing care and support for Alzheimer’s patients and caregivers</p>

            @* Display TempData message if available *@
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success text-center">
                    @TempData["Message"]
                </div>
            }

            @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
            {
                <div class="mb-3">
                    <input type="email" name="email"
                           class="form-control"
                           placeholder="Enter your email"
                           required>
                </div>
                <div class="mb-3">
                    <input type="password" name="password"
                           class="form-control"
                           placeholder="Enter your password"
                           required>
                </div>
                <button type="submit" class="btn btn-primary">Login</button>
            }

            <p class="mt-3">
                Don't have an account?
                <a asp-controller="Auth" asp-action="Register">Create account</a>
                <a asp-controller="Auth" asp-action="ForgotPassword">Reset Password</a>
            </p>
         
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-auth.js"></script>

</body>
</html>
